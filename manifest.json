{
  "manifest_version": 3,
  "name": "slide-v2 [DEV]",
  "description": "Slide OpenStreetMap geometry to the Strava heatmap, right in the iD editor.",
  "version": "0.0.1",
  "action": {
    "default_title": "slide-v2"
  },
  "minimum_chrome_version": "111",
  "content_scripts": [
    {
      "matches": ["*://www.openstreetmap.org/id*"],
      "js": ["src/page/capture-context.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": ["*://www.openstreetmap.org/id*"],
      "js": ["src/page/heatmap.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": ["*://www.openstreetmap.org/id*"],
      "js": ["src/page/slide-core.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": ["*://www.openstreetmap.org/id*"],
      "js": ["src/page/slide-operation.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "world": "MAIN"
    }
  ]
}
