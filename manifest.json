{
  "manifest_version": 3,
  "name": "slide-v2 [DEV]",
  "description": "Slide OpenStreetMap geometry to the Strava heatmap, right in the iD editor.",
  "version": "0.0.1",
  "action": {
    "default_title": "slide-v2"
  },
  "content_scripts": [
    {
      "matches": ["*://www.openstreetmap.org/id*"],
      "js": ["src/content/content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
